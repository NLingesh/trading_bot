# Binance Futures Testnet — API credentials
# Get your Testnet keys from: https://testnet.binancefuture.com
# Copy this file to .env and fill in your real values. NEVER commit .env.

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Testnet base URL — do NOT change unless Binance updates it
BINANCE_BASE_URL=https://testnet.binancefuture.com
